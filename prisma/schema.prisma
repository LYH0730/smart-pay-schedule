generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  shopName  String   @default("나의 가게")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
